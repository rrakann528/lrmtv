modules = ["nodejs-20", "web", "bash", "python-3.11"]
[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
NODE_ENV = "development"
JWT_SECRET = "15c2d29827ec073660cfa1f29245a89be5f7c4f6d966ce5c4197584842bd2b81"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/web && PORT=5000 pnpm dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 5173

[[ports]]
localPort = 8084
externalPort = 6800

[[ports]]
localPort = 22333
externalPort = 3001

[[ports]]
localPort = 22334
externalPort = 3003

[[ports]]
localPort = 22335
externalPort = 4200

[[ports]]
localPort = 22336
externalPort = 8000

[deployment]
deploymentTarget = "vm"
run = ["bash", "start.sh"]
build = ["bash", "-c", "pnpm install --no-frozen-lockfile && BASE_PATH=/ pnpm --filter @workspace/web build && pnpm --filter @workspace/api-server build"]
